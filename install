#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")" || exit

HOME_DIR="$HOME"
DOTFILES_DIR="$HOME_DIR/dotfiles"
ENV_FILE="$HOME_DIR/.dotfiles-env"
PLATFORM="$(uname -s)"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
ORANGE='\033[0;33m'
NC='\033[0m'

green() { echo -e "${GREEN}$*${NC}"; }
yellow() { echo -e "${YELLOW}$*${NC}"; }
orange() { echo -e "${ORANGE}$*${NC}"; }

stow_pkg() {
    local flags=("$@")
    stow -R --adopt -d "$DOTFILES_DIR" -t "$HOME_DIR" "${flags[@]}"
}

link_file() {
    local src="$1" dest="$2"
    if [[ -e "$dest" || -L "$dest" ]]; then
        green "  ✔ $(basename "$dest") already linked"
        return
    fi
    ln -s "$src" "$dest"
    green "  🔗 Linked $(basename "$dest")"
}

detect_environment() {
    if [[ -f "$ENV_FILE" ]]; then
        green "✔ Environment already set: $(cat "$ENV_FILE")"
    else
        echo "Which environment is this?"
        echo "  1) work"
        echo "  2) personal"
        read -rp "Select [1/2]: " choice
        case "$choice" in
        1) echo "work" >"$ENV_FILE" ;;
        *) echo "personal" >"$ENV_FILE" ;;
        esac
    fi
    DOTFILES_ENV="$(cat "$ENV_FILE")"
    export DOTFILES_ENV
}

clone_work_config() {
    if [[ "$DOTFILES_ENV" != "work" ]]; then
        return
    fi
    if [[ -d "$DOTFILES_DIR/env/work" ]]; then
        green "✔ Work config already cloned"
        return
    fi
    green "📦 Cloning work environment config..."
    git clone git@github.com:ellord/work-private-dotfiles.git "$DOTFILES_DIR/env/work"
}

link_stow_packages() {
    green "🔧 Linking stow packages..."
    stow_pkg vim
    stow_pkg opencode
    stow_pkg --dotfiles zsh
    stow_pkg tmux
    stow_pkg mise
    if [[ "$PLATFORM" == "Darwin" ]]; then
        stow_pkg wezterm
    fi
}

link_manual_packages() {
    green "🔧 Linking manual packages..."
    link_file "$DOTFILES_DIR/nvim-config" "$HOME_DIR/.config/nvim"
    if [[ "$PLATFORM" == "Darwin" ]]; then
        link_file "$DOTFILES_DIR/ghostty/config" "$HOME_DIR/Library/Application Support/com.mitchellh.ghostty/config"
    else
        link_file "$DOTFILES_DIR/ghostty/config" "$HOME_DIR/.config/ghostty/config"
    fi
    link_file "$DOTFILES_DIR/claude/.claude/settings.json" "$HOME_DIR/.claude/settings.json"
    link_file "$DOTFILES_DIR/claude/.claude/statusline.sh" "$HOME_DIR/.claude/statusline.sh"
    link_file "$DOTFILES_DIR/claude/.claude/dark-notify-claude.sh" "$HOME_DIR/.claude/dark-notify-claude.sh"
}

link_lazygit_theme() {
    if [[ -L "$HOME_DIR/.config/lazygit/theme.yml" ]]; then
        green "  ✔ lazygit theme already linked"
        return
    fi
    mkdir -p "$HOME_DIR/.config/lazygit"
    local use_dark=true
    if [[ "$PLATFORM" == "Darwin" ]] && [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" != "Dark" ]]; then
        use_dark=false
    fi
    if $use_dark; then
        ln -s "$DOTFILES_DIR/lazygit/theme-dark.yml" "$HOME_DIR/.config/lazygit/theme.yml"
    else
        ln -s "$DOTFILES_DIR/lazygit/theme-light.yml" "$HOME_DIR/.config/lazygit/theme.yml"
    fi
    green "  🔗 Linked lazygit theme"
}

install_tmux_plugins() {
    if [[ -d "$HOME_DIR/.tmux/plugins/tpm" ]]; then
        green "✔ TPM already installed"
    else
        green "📦 Installing tmux plugin manager..."
        mkdir -p "$HOME_DIR/.tmux/plugins"
        git clone https://github.com/tmux-plugins/tpm "$HOME_DIR/.tmux/plugins/tpm"
    fi

    if [[ "$PLATFORM" == "Darwin" ]]; then
        if [[ -d "$HOME_DIR/.tmux/plugins/tmux-dark-notify" ]]; then
            green "✔ tmux-dark-notify already installed"
        else
            green "📦 Installing tmux-dark-notify..."
            git clone https://github.com/erikw/tmux-dark-notify "$HOME_DIR/.tmux/plugins/tmux-dark-notify"
        fi
    fi

    chmod +x "$HOME_DIR/.tmux/themes/"*.tmux 2>/dev/null || true
}

setup_gitconfig() {
    if [[ -f "$HOME_DIR/.gitconfig" ]]; then
        green "✔ gitconfig already exists"
        return
    fi

    green "🔧 Setting up gitconfig..."
    cat >"$HOME_DIR/.gitconfig" <<'GITCONF'
[include]
    path = ~/dotfiles/git/.gitconfig

[include]
    path = ~/.gitconfig.local
GITCONF

    if [[ ! -f "$HOME_DIR/.gitconfig.local" ]]; then
        echo ""
        yellow "⚠️  Create ~/.gitconfig.local with your [user] name and email:"
        orange '  git config --file ~/.gitconfig.local user.name "Your Name"'
        orange '  git config --file ~/.gitconfig.local user.email "you@example.com"'
    fi
}

green "🚀 Installing dotfiles..."
echo ""

detect_environment
clone_work_config
link_stow_packages
link_manual_packages
link_lazygit_theme
install_tmux_plugins
setup_gitconfig

echo ""
green "✅ Install complete!"
