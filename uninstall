#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")" || exit

HOME_DIR="$HOME"
DOTFILES_DIR="$HOME_DIR/dotfiles"
PLATFORM="$(uname -s)"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

green() { echo -e "${GREEN}$*${NC}"; }
yellow() { echo -e "${YELLOW}$*${NC}"; }

unstow_pkg() {
    local flags=("$@")
    if stow -d "$DOTFILES_DIR" -t "$HOME_DIR" -D "${flags[@]}" 2>/dev/null; then
        green "  ✔ Unlinked ${flags[-1]}"
    fi
}

remove_link() {
    local target="$1"
    if [[ -L "$target" ]]; then
        rm "$target"
        green "  ✔ Unlinked $target"
    fi
}

unlink_stow_packages() {
    green "🧹 Removing stow packages..."
    unstow_pkg vim
    unstow_pkg opencode
    unstow_pkg --dotfiles zsh
    unstow_pkg tmux
    unstow_pkg mise
    if [[ "$PLATFORM" == "Darwin" ]]; then
        unstow_pkg wezterm
    fi
}

unlink_manual_packages() {
    green "🧹 Removing manual symlinks..."
    remove_link "$HOME_DIR/.config/nvim"
    if [[ "$PLATFORM" == "Darwin" ]]; then
        remove_link "$HOME_DIR/Library/Application Support/com.mitchellh.ghostty/config"
    else
        remove_link "$HOME_DIR/.config/ghostty/config"
    fi
    remove_link "$HOME_DIR/.claude/settings.json"
    remove_link "$HOME_DIR/.claude/statusline.sh"
    remove_link "$HOME_DIR/.claude/dark-notify-claude.sh"
    remove_link "$HOME_DIR/.config/lazygit/theme.yml"
}

green "🧹 Uninstalling dotfiles..."
echo ""

unlink_stow_packages
unlink_manual_packages

echo ""
green "✅ Uninstall complete!"
echo ""
yellow "⚠️  The following were NOT removed (manage manually if needed):"
echo "  ~/.gitconfig          (generated, not a symlink)"
echo "  ~/.gitconfig.local    (personal config)"
echo "  ~/.tmux/plugins/      (cloned repos)"
echo "  ~/.dotfiles-env       (environment marker)"
