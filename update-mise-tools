#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1

CONFIG_FILE="mise/.config/mise/config.toml"
DRY_RUN=false
INCLUDE_RUNTIMES=false
COMMIT=true

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

green() { printf '%b\n' "${GREEN}$*${NC}"; }
yellow() { printf '%b\n' "${YELLOW}$*${NC}"; }
red() { printf '%b\n' "${RED}$*${NC}"; }

usage() {
    cat <<'EOF'
Usage: ./update-mise-tools [--dry-run] [--include-runtimes] [--no-commit]

Updates the pinned claude-code version to the latest available release,
then upgrades tools from the CLI sections of mise/.config/mise/config.toml.

Options:
  --dry-run           Show planned changes without installing anything
  --include-runtimes  Also upgrade language runtimes within their configured ranges
  --no-commit         Skip committing the claude-code version bump to git
  -h, --help          Show this help text
EOF
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || {
        red "Missing required command: $1"
        exit 1
    }
}

list_tools_in_section() {
    local wanted_section="$1"

    awk -v wanted_section="$wanted_section" '
        /^\[tools\]/ { in_tools = 1; next }
        /^\[/ && !/^\[tools\]/ { in_tools = 0 }
        !in_tools { next }

        /^# Language runtimes$/ { section = "runtime"; next }
        /^# CLI tools$/ { section = "cli"; next }
        /^# Backend-specific tools$/ { section = "backend"; next }
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
        section != wanted_section { next }

        {
            split($0, parts, "=")
            key = parts[1]
            value = parts[2]

            gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
            gsub(/^["\047]|["\047]$/, "", key)
            gsub(/^["\047]|["\047]$/, "", value)

            if (wanted_section == "runtime" || value == "latest") {
                print key
            }
        }
    ' "$CONFIG_FILE"
}

read_tool_version() {
    local wanted_tool="$1"

    awk -v wanted_tool="$wanted_tool" '
        /^\[tools\]/ { in_tools = 1; next }
        /^\[/ && !/^\[tools\]/ { in_tools = 0 }
        !in_tools { next }
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }

        {
            split($0, parts, "=")
            key = parts[1]
            value = parts[2]

            gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
            gsub(/^["\047]|["\047]$/, "", key)
            gsub(/^["\047]|["\047]$/, "", value)

            if (key == wanted_tool) {
                print value
                exit
            }
        }
    ' "$CONFIG_FILE"
}

append_section_tools() {
    local section="$1"
    local tool

    while IFS= read -r tool; do
        [[ -n "$tool" ]] || continue
        TARGET_TOOLS+=("$tool")
    done < <(list_tools_in_section "$section")
}

while [[ $# -gt 0 ]]; do
    case "$1" in
    --dry-run)
        DRY_RUN=true
        ;;
    --include-runtimes)
        INCLUDE_RUNTIMES=true
        ;;
    --no-commit)
        COMMIT=false
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    *)
        red "Unknown option: $1"
        echo
        usage
        exit 1
        ;;
    esac
    shift
done

[[ -f "$CONFIG_FILE" ]] || {
    red "Missing config file: $CONFIG_FILE"
    exit 1
}

require_command mise
require_command perl

if $COMMIT; then
    require_command git
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        red "--commit requires running inside a git repository"
        exit 1
    fi
    if ! git diff --quiet -- "$CONFIG_FILE" || ! git diff --cached --quiet -- "$CONFIG_FILE"; then
        red "Refusing to --commit: ${CONFIG_FILE} has pre-existing local changes"
        exit 1
    fi
fi

current_claude_version="$(read_tool_version "claude-code")"
latest_claude_version="$(mise latest claude-code)"
active_claude_version="$(mise current claude-code 2>/dev/null || true)"

[[ -n "$current_claude_version" ]] || {
    red "Could not read claude-code from $CONFIG_FILE"
    exit 1
}

[[ -n "$latest_claude_version" ]] || {
    red "Could not determine the latest claude-code version"
    exit 1
}

if [[ "$current_claude_version" == "$latest_claude_version" ]]; then
    green "claude-code is already pinned at ${current_claude_version}"
else
    yellow "claude-code pin: ${current_claude_version} -> ${latest_claude_version}"
fi

should_install_claude=false
if [[ "$current_claude_version" != "$latest_claude_version" ]]; then
    should_install_claude=true
elif [[ -z "$active_claude_version" || "$active_claude_version" != "$current_claude_version" ]]; then
    should_install_claude=true
fi

if $DRY_RUN; then
    if [[ "$current_claude_version" != "$latest_claude_version" ]]; then
        yellow "Would update ${CONFIG_FILE}"
    fi
    if $should_install_claude; then
        yellow "Would install claude-code@${latest_claude_version}"
    fi
else
    if [[ "$current_claude_version" != "$latest_claude_version" ]]; then
        LATEST_CLAUDE_VERSION="$latest_claude_version" \
            perl -0pi -e 's/^(claude-code\s*=\s*["\047]).*?(["\047])/$1 . $ENV{LATEST_CLAUDE_VERSION} . $2/me' "$CONFIG_FILE"
    fi

    if $should_install_claude; then
        mise install claude-code
        mise reshim claude-code >/dev/null
    fi
fi

declare -a TARGET_TOOLS=()
append_section_tools cli
append_section_tools backend

if $INCLUDE_RUNTIMES; then
    append_section_tools runtime
fi

declare -a planned_tools=()
declare -a upgraded_tools=()
declare -a failed_tools=()

for tool in "${TARGET_TOOLS[@]}"; do
    if [[ -z "$(mise outdated --no-header "$tool" 2>/dev/null || true)" ]]; then
        continue
    fi

    if $DRY_RUN; then
        planned_tools+=("$tool")
        yellow "Would upgrade ${tool}"
        continue
    fi

    yellow "Upgrading ${tool}"
    if mise upgrade "$tool"; then
        upgraded_tools+=("$tool")
    else
        failed_tools+=("$tool")
        red "Failed to upgrade ${tool}"
    fi
done

echo
green "Summary"

if $DRY_RUN; then
    if [[ "$current_claude_version" == "$latest_claude_version" ]] && [[ ${#planned_tools[@]} -eq 0 ]]; then
        green "Everything is already up to date"
        exit 0
    fi

    if [[ "$current_claude_version" != "$latest_claude_version" ]]; then
        yellow "claude-code would be pinned to ${latest_claude_version}"
        if $COMMIT; then
            yellow "would commit: Bump claude to ${latest_claude_version}"
        fi
    fi

    if [[ ${#planned_tools[@]} -gt 0 ]]; then
        for tool in "${planned_tools[@]}"; do
            yellow "tool would be upgraded: ${tool}"
        done
    fi

    exit 0
fi

if [[ "$current_claude_version" != "$latest_claude_version" ]]; then
    green "claude-code pinned to ${latest_claude_version}"
fi

if [[ ${#upgraded_tools[@]} -gt 0 ]]; then
    for tool in "${upgraded_tools[@]}"; do
        green "tool upgraded: ${tool}"
    done
fi

if [[ ${#failed_tools[@]} -gt 0 ]]; then
    for tool in "${failed_tools[@]}"; do
        yellow "tool failed: ${tool}"
    done
fi

if [[ "$current_claude_version" == "$latest_claude_version" ]] &&
    [[ ${#upgraded_tools[@]} -eq 0 ]] &&
    [[ ${#failed_tools[@]} -eq 0 ]]; then
    green "Everything is already up to date"
fi

if $COMMIT; then
    if git diff --quiet -- "$CONFIG_FILE"; then
        green "Nothing to commit"
    else
        git add -- "$CONFIG_FILE"
        git commit -m "Bump claude to ${latest_claude_version}"
        green "Committed claude-code bump to ${latest_claude_version}"
    fi
fi
